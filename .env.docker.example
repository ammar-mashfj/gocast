# Copy to `.env` at the repo root — docker compose auto-loads this file.
# Dev defaults below are safe for local use only; rotate everything for prod.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootdev
MYSQL_DATABASE=gocast
MYSQL_USER=gocast
MYSQL_PASSWORD=gocastdev

# --- Icecast ---
# Rendered into icecast.xml.tpl at container start by the Icecast entrypoint.
# Rotate here + restart icecast/relay/liquidsoap to rotate everywhere; no need
# to edit any XML.
ICECAST_SOURCE_PASSWORD=docker-dev
ICECAST_RELAY_PASSWORD=docker-dev
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=docker-dev

# --- Relay ↔ API shared secret ---
INTERNAL_API_KEY=dev-internal-key

# --- FrankenPHP / Caddy ---
# Dev: `:80` — plain HTTP, no cert negotiation.
# Prod (direct, no Cloudflare): your real hostname (e.g. `api.gocast.fm`) —
#   Caddy auto-requests a Let's Encrypt cert on boot and renews in the
#   background. Requires ports 80 and 443 reachable on the host.
# Prod (Cloudflare in front): also set to your real hostname, AND uncomment
#   the Caddyfile.cloudflare volume mount in docker-compose.yml's api service
#   AND drop the CF Origin Certificate pair into infra/certs/ (see the README
#   in that directory). CF SSL mode must be "Full (strict)".
SERVER_NAME=:80

# --- Production hostnames (only used with docker-compose.prod.yml) ---
# Baked into the client bundle at build time — make sure these are correct
# before running `docker compose -f docker-compose.yml -f docker-compose.prod.yml build client`.
API_HOSTNAME=api.gocast.fm
APP_HOSTNAME=gocast.fm
ICECAST_HOSTNAME=icecast.gocast.fm
RELAY_HOSTNAME=relay.gocast.fm

# --- Observability (only used with docker-compose.observability.yml) ---
# Grafana Cloud: Home → My Account → Select stack → "Details" on each data
# source. Create an API token scoped to metrics:write + logs:write.
HOSTNAME=gocast-prod
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-006.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=
GRAFANA_CLOUD_LOKI_API_KEY=
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-13-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USERNAME=
GRAFANA_CLOUD_PROM_API_KEY=

# --- Sentry ---
# Laravel side: set SENTRY_LARAVEL_DSN in api/.env (NOT here). Compose
# picks it up via env_file: ./api/.env on the api service.
#   SENTRY_LARAVEL_DSN=https://...@o<org>.ingest.sentry.io/<project>
#
# Client side: both vars below are consumed as BUILD args (Next.js inlines
# the DSN into the browser bundle at build time, and the auth token is used
# by @sentry/nextjs's webpack plugin to upload source maps). Runtime env
# wouldn't do anything for these.
#   - DSN: Sentry dashboard → Project → Settings → Client Keys (DSN)
#   - Auth token: Sentry dashboard → User → Auth Tokens → create with
#     `project:releases` + `org:read` scopes
# Both are safe to leave blank in local dev — the Sentry plugin skips
# cleanly. In prod, leave SENTRY_AUTH_TOKEN blank if you don't want source
# map upload (stack traces will be minified but everything still works).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
