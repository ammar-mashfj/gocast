<ezstream>
    <!--
        Feeds the /standby.mp3 mount on Icecast. Icecast is configured (via
        <mount type="default"><fallback-mount>/standby.mp3</fallback-mount>)
        to transparently route listeners of any dynamic /stream/* mount to
        this stream whenever a broadcaster's SOURCE disconnects. When the
        broadcaster reconnects, listeners are moved back to the live stream.

        Schema: ezstream 1.0+ (Ubuntu 22.04 ships 1.0.2).
        Deployed to: /etc/gocast/standby.xml on the production host.
        Run by:      /etc/systemd/system/gocast-standby.service.

        Companion file: /etc/gocast/standby.m3u — a one-line playlist that
        points at the MP3. Using a playlist intake (not type="file") gives
        us guaranteed looping via stream_once=0.
    -->

    <servers>
        <server>
            <name>icecast-local</name>
            <protocol>http</protocol>
            <hostname>localhost</hostname>
            <port>8888</port>
            <user>source</user>
            <password>06011995</password>
        </server>
    </servers>

    <streams>
        <stream>
            <mountpoint>/standby.mp3</mountpoint>
            <intake>standby-loop</intake>
            <server>icecast-local</server>
            <public>No</public>
            <format>MP3</format>
            <stream_name>GoCast standby</stream_name>
        </stream>
    </streams>

    <intakes>
        <intake>
            <name>standby-loop</name>
            <type>playlist</type>
            <filename>/etc/gocast/standby.m3u</filename>
            <shuffle>No</shuffle>
            <stream_once>0</stream_once>
        </intake>
    </intakes>
</ezstream>
