# Laravel API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Public-facing app URL (used for OG tags, player links, Google OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebSocket relay URL for broadcasting (use wss:// in production)
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Icecast stream URL for player audio playback (use https:// in production)
NEXT_PUBLIC_ICECAST_URL=http://localhost:8888
